{
  "name": "kashika-portfolio",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "homepage": "https://kashika222.github.io/kashika-chopra-portfolio/",
  "scripts": {
    "dev": "cp index.source.html index.html && vite",
    "build": "cp index.source.html index.html && tsc && vite build && cp -r dist/* .",
    "preview": "vite preview",
    "predeploy": "npm run build",
    "deploy": "npm run build && git add -A && git commit -m 'Deploy portfolio' && git push"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.23",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.19",
    "typescript": "~5.6.2",
    "vite": "^6.0.1"
  }
}
